---
import Chevron from "./Chevron.astro";

interface Props {
  ariaLabel?: string;
  class?: string;
}

const { ariaLabel = "Toggle details", class: className = "" } = Astro.props;
---

<button
  type="button"
  class:list={["chevron-toggle", className]}
  aria-label={ariaLabel}
  aria-expanded="false"
>
  <Chevron size={20} />
</button>

<style>
  .chevron-toggle {
    background: none;
    border: none;
    color: var(--secondary-text);
    cursor: pointer;
    padding: 0.25rem;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .chevron-toggle > :global(.chevron) {
    translate: 0 0;
    transition:
      translate 0.2s ease,
      transform 0.2s ease;
  }

  .chevron-toggle:hover {
    color: var(--accent);
    background: var(--bg);
  }

  .chevron-toggle:hover > :global(.chevron) {
    translate: 0 4px;
  }

  .chevron-toggle.active > :global(.chevron) {
    transform: rotate(180deg);
  }

  .chevron-toggle.active:hover > :global(.chevron) {
    translate: 0 -4px;
  }
</style>
