---
interface Props {
  direction?: "left" | "right";
  size?: number;
}

const { direction = "right", size = 12 } = Astro.props;
---

<svg
  class:list={["arrow", direction === "left" && "arrow--left"]}
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 26 26"
  fill="none"
  stroke="currentColor"
  stroke-width="4"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  ><line x1="2" y1="14" x2="20" y2="14"></line><polyline
    points="15 7 20 14 15 21"></polyline></svg
>

<style>
  .arrow {
    display: inline-block;
    transition: translate 0.2s ease;
  }

  .arrow--left {
    transform: scaleX(-1);
  }
</style>
