---
// Giscus comments — requires GitHub Discussions enabled on the repo.
// Fill in REPO_ID and CATEGORY_ID from https://giscus.app after setup.
---

<section class="comments" aria-label="Comments">
  <h2 class="comments-heading">Discussion</h2>
  <script
    src="https://giscus.app/client.js"
    data-repo="MatricalDefunkt/matricaldefunkt.github.io"
    data-repo-id="REPO_ID"
    data-category="Blog Comments"
    data-category-id="CATEGORY_ID"
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="top"
    data-theme="dark_dimmed"
    data-lang="en"
    crossorigin="anonymous"
    async
  ></script>
</section>

<style>
  .comments {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--card-border);
  }

  .comments-heading {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-color);
    margin: 0 0 1.5rem;
  }
</style>
