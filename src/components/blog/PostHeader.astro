---
import Badge from "../ui/Badge.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  readingTime: number;
  series?: string;
  seriesOrder?: number;
}

const { title, description, date, tags, readingTime, series, seriesOrder } =
  Astro.props;
const formattedDate = date.toLocaleDateString("en-GB", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<header class="post-header">
  {
    series && (
      <div class="post-series">
        <span class="series-label">Series</span>
        <span class="series-name">
          {series}
          {seriesOrder
            ? ` \u00A0\u00A0\u00A0|\u00A0\u00A0\u00A0 Part ${seriesOrder}`
            : ""}
        </span>
      </div>
    )
  }
  <h1 class="post-title">{title}</h1>
  <p class="post-description">{description}</p>
  <div class="post-meta">
    <time datetime={date.toISOString()} class="post-date">{formattedDate}</time>
    <span class="post-reading-time">{readingTime} min read</span>
  </div>
  {
    tags.length > 0 && (
      <div class="post-tags">
        {tags.map((tag) => (
          <Badge text={tag} />
        ))}
      </div>
    )
  }
</header>

<style>
  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--card-border);
  }

  .post-series {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.85rem;
  }

  .series-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent-color);
    border: 1px solid var(--card-border);
    border-radius: 4px;
    padding: 0.15rem 0.45rem;
  }

  .series-name {
    font-size: 0.85rem;
    color: var(--secondary-text);
  }

  .post-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-color);
    line-height: 1.25;
    margin: 0 0 0.85rem;
  }

  .post-description {
    font-size: 1.05rem;
    color: var(--secondary-text);
    line-height: 1.65;
    margin: 0 0 1.25rem;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .post-date {
    font-size: 0.88rem;
    color: var(--secondary-text);
  }

  .post-reading-time {
    font-size: 0.88rem;
    color: var(--secondary-text);
  }

  .post-reading-time::before {
    content: "·";
    margin-right: 0.5rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  @media (max-width: 1000px) {
    .post-title {
      font-size: 1.55rem;
    }
  }
</style>
