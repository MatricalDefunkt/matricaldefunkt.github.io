---
import FloatingLinks from "../../components/ui/FloatingLinks.astro";
---

<header class="header-bio">
  <FloatingLinks />
  <div class="hero-content">
    <p class="intro">
      I'm an Infrastructure & Backend Engineer, and a <strong
        >Node.js Core Contributor</strong
      >, based in Pune, India. I build robust cloud-native systems and scalable
      backend architectures.
    </p>
    <button
      type="button"
      id="contact-scroll-btn"
      class="contact-cta"
      aria-label="Scroll to contact form"
    >
      Contact Me
    </button>
    <div class="author-info">
      <img src="/profile.jpg" alt="Pramit Sharma" class="profile-photo" />
      <span class="author-name">Pramit Sharma</span>
    </div>
    <FloatingLinks mobile={true} />
  </div>
</header>

<style>
  .header-bio {
    position: relative;
    width: 100%;
  }

  .hero-content {
    max-width: 100%;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .intro {
    font-size: 1.75rem;
    color: var(--text-color);
    line-height: 1.5;
    margin: 0;
    font-weight: 300;
  }

  .intro strong {
    font-weight: 600;
    color: var(--text-color);
  }

  .contact-cta {
    margin-top: 1.2rem;
    border: 1px solid var(--card-border);
    border-radius: 8px;
    background: var(--card-bg);
    color: var(--text-color);
    font: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    padding: 0.6rem 1rem;
    cursor: pointer;
    transition:
      border-color 0.2s ease,
      transform 0.2s ease,
      color 0.2s ease;
  }

  .contact-cta:hover {
    border-color: var(--accent-color);
    transform: translateY(-2px);
  }

  .contact-cta:focus-visible {
    outline: 2px solid var(--accent-color);
    outline-offset: 2px;
  }

  .author-info {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    margin-top: 3rem;
  }

  .profile-photo {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--card-border);
    display: block;
  }

  .author-name {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-color);
    letter-spacing: 0.02em;
  }

  @media (max-width: 1000px) {
    .intro {
      font-size: 1.35rem;
    }

    .author-info {
      margin-top: 2rem;
    }
  }
</style>

<script>
  const contactScrollBtn = document.getElementById(
    "contact-scroll-btn",
  ) as HTMLButtonElement | null;
  const footerContactForm = document.getElementById(
    "footer-contact-form",
  ) as HTMLFormElement | null;

  contactScrollBtn?.addEventListener("click", () => {
    if (!footerContactForm) return;
    footerContactForm.scrollIntoView({ behavior: "smooth", block: "start" });
  });
</script>
